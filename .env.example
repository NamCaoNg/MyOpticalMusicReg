LOG_LEVEL=info
APP_NAME=OMR Model Service
APP_VERSION=1.0.0

# Frontend origins allowed to call this API.
# Use comma-separated values in production, for example:
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.example.com
CORS_ORIGINS=*

# Public model-service URL used to build file URLs for the calling backend.
# Leave empty for relative URLs such as /outputs/<job>/<file>.
# PUBLIC_BASE_URL=http://localhost:8000

# Optional shared secret for service-to-service calls.
# When set, callers must send: X-API-Key: <value>
OMR_API_KEY=change-me

# Disable in public deployments if you do not want to expose Swagger/OpenAPI.
ENABLE_DOCS=true

# Comma-separated host allowlist. For ngrok, set your ngrok host here.
# Example: TRUSTED_HOSTS=example.ngrok-free.app,localhost,127.0.0.1
TRUSTED_HOSTS=*

# Upload guardrail for score images.
MAX_UPLOAD_MB=15

# Keep false in production. When true, API responses include local server paths.
INCLUDE_LOCAL_PATHS=false

# Keep false for lighter API responses. Callers can still request XML per request:
# POST /api/v1/omr/process?include_xml_content=true
INCLUDE_XML_CONTENT_DEFAULT=false

# Keep false to remove uploaded source images after each request.
KEEP_UPLOADS=false

# TensorFlow inference tuning.
# Lower batch size if Kaggle GPU memory is tight; raise it if GPU memory is free.
OMR_TF_BATCH_SIZE=16

# Target image size before patch inference. Lower values are faster but may reduce accuracy.
OMR_RESIZE_MIN_PIXELS=3000000
OMR_RESIZE_MAX_PIXELS=3500000

# When true, load both TensorFlow models during startup instead of first request.
OMR_WARMUP_MODELS=false

# Optional absolute paths for deployment.
# Keep these commented for local development unless you want runtime files outside backend/.
# UPLOADS_DIR=/var/www/simple-omr/uploads
# OUTPUTS_DIR=/var/www/simple-omr/outputs
# CHECKPOINTS_DIR=/var/www/simple-omr/checkpoints
# SKLEARN_MODELS_DIR=/var/www/simple-omr/sklearn_models
